# Optional: force Python interpreter for transcription
# GLASSCALL_PYTHON=/path/to/glasscall-notes/python-worker/.venv/bin/python3

# PyTorch device override for the worker: cpu | mps | cuda
# GLASSCALL_DEVICE=cpu

# Hugging Face token (also configurable in app Settings) — required for pyannote diarization
# HF_TOKEN=hf_...
